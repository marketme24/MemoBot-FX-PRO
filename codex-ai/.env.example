# MEMOCODEX AI — Provider-Agnostic Configuration
# Choose ANY OpenAI-compatible API provider. All are optional.

# AI_BASE_URL: The base URL of your AI provider's OpenAI-compatible endpoint.
# Examples:
#   Groq (free):        https://api.groq.com/openai/v1
#   HuggingFace (free): https://api-inference.huggingface.co/v1
#   Ollama (local):     http://localhost:11434/v1
#   OpenRouter:         https://openrouter.ai/api/v1
#   Together AI:        https://api.together.xyz/v1
#   Google Gemini:      https://generativelanguage.googleapis.com/v1beta/openai
#   Cohere:             https://api.cohere.com/compatibility/v1
#   LM Studio (local):  http://localhost:1234/v1
#   Any custom:         https://your-endpoint.com/v1
AI_BASE_URL="https://api.groq.com/openai/v1"

# AI_API_KEY: Your API key for the chosen provider.
# Not needed for local providers like Ollama or LM Studio.
AI_API_KEY=""

# AI_MODEL: The model to use.
# Examples:
#   Groq:        llama-3.3-70b-versatile
#   HuggingFace: mistralai/Mistral-7B-Instruct-v0.3
#   Ollama:      llama3
#   OpenRouter:  meta-llama/llama-3.3-70b-instruct:free
#   Together:    meta-llama/Llama-3.3-70B-Instruct-Turbo-Free
#   Gemini:      gemini-2.0-flash
#   Cohere:      command-r
AI_MODEL="llama-3.3-70b-versatile"
